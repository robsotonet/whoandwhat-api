# Environment variables for Docker Compose
# This file can be committed as it contains only development defaults

# PostgreSQL Database
POSTGRES_DB=WhoAndWhat
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@whoandwhat.local
PGADMIN_DEFAULT_PASSWORD=admin

# Application Configuration
ASPNETCORE_ENVIRONMENT=Development
JWT_SECRET_KEY=YourDevelopmentSecretKeyHere_MinimumLength32Characters_DockerDevelopment