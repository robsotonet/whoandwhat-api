{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/whoandwhat-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=whoandwhat;Username=postgres;Password=postgres",
    "ApplicationInsights": ""
  },
  "ApiSettings": {
    "Title": "WhoAndWhat Task Management API",
    "Version": "v1",
    "Description": "A comprehensive bilingual task management platform with AI-powered features and social connectivity."
  },
  "HealthChecks": {
    "UI": {
      "HealthCheckDatabaseConnectionString": "Data Source=healthchecks.db"
    }
  },
  "AllowedHosts": "*"
}
