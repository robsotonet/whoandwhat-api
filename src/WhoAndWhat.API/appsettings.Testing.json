{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Error",
        "System": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[TEST] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=whoandwhat_test;Username=postgres;Password=postgres",
    "ApplicationInsights": ""
  },
  "RedisCache": {
    "ConnectionString": "localhost:6379",
    "DefaultExpirationMinutes": 1,
    "TaskCacheExpirationMinutes": 1,
    "TaskListCacheExpirationMinutes": 1,
    "UserTaskSummaryCacheExpirationMinutes": 1,
    "EnableCacheWarming": false,
    "MaxCacheWarmItems": 10,
    "DatabaseIndex": 1,
    "EnablePerformanceMonitoring": false,
    "KeyPrefix": "whoandwhat_test",
    "ConnectionTimeoutMs": 1000,
    "CommandTimeoutMs": 1000,
    "MaxRetryAttempts": 1,
    "EnableCacheFallback": false
  },
  "ApiSettings": {
    "Title": "WhoAndWhat Test API",
    "Version": "v1",
    "Description": "Test environment for WhoAndWhat API"
  },
  "HealthChecks": {
    "UI": {
      "HealthCheckDatabaseConnectionString": "Data Source=healthchecks_test.db"
    }
  },
  "AllowedHosts": "*",
  "OAuth": {
    "Google": {
      "ClientId": "test-google-client-id",
      "ClientSecret": "test-google-client-secret",
      "Scope": "openid profile email"
    },
    "Facebook": {
      "AppId": "test-facebook-app-id",
      "AppSecret": "test-facebook-app-secret",
      "Scope": "email public_profile"
    },
    "Apple": {
      "ClientId": "test-apple-client-id",
      "TeamId": "test-apple-team-id",
      "KeyId": "test-apple-key-id",
      "PrivateKey": "test-apple-private-key",
      "Scope": "name email"
    },
    "CallbackUrl": {
      "BaseUrl": "http://localhost:5000",
      "Google": "/api/v1/oauth/google/callback",
      "Facebook": "/api/v1/oauth/facebook/callback",
      "Apple": "/api/v1/oauth/apple/callback"
    }
  },
  "JWT": {
    "SecretKey": "TestingSuperSecretKeyThatShouldBeAtLeast32CharactersLong!",
    "Issuer": "WhoAndWhatAPI-Test",
    "Audience": "WhoAndWhatClients-Test",
    "ExpirationMinutes": 60,
    "RefreshExpirationDays": 7,
    "ValidateIssuerSigningKey": true,
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateLifetime": true,
    "RequireExpirationTime": true,
    "ClockSkewMinutes": 5
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": false,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100000
      }
    ]
  },
  "ClientRateLimiting": {
    "EnableEndpointRateLimiting": false,
    "StackBlockedRequests": false,
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100000
      }
    ]
  },
  "KeyVault": {
    "Endpoint": ""
  },
  "DDoSProtection": {
    "Enabled": false,
    "DetailedLogging": false,
    "WhitelistedIPs": [
      "127.0.0.1",
      "::1",
      "localhost"
    ],
    "BlockDurationMinutes": 1,
    "MaxRequestsPerWindow": 100000,
    "RequestFrequencyWindowMinutes": 60,
    "ScoreAccumulationWindowMinutes": 60,
    "PatternAnalysisWindowMinutes": 60,
    "BlockingThreshold": 100000,
    "ImmediateBlockThreshold": 100000,
    "LogSuspiciousThreshold": 100000,
    "BotUserAgentPenalty": 0,
    "SuspiciousPathPenalty": 0,
    "HighFrequencyPenalty": 0,
    "ExcessiveEndpointsPenalty": 0,
    "UserAgentVariationPenalty": 0,
    "MaxUniqueEndpointsThreshold": 100000,
    "MaxUserAgentChangesThreshold": 100000
  },
  "SecurityHeaders": {
    "Enabled": false,
    "RemoveServerHeader": false,
    "HSTS": {
      "Enabled": false
    },
    "ContentSecurityPolicy": {
      "Enabled": false
    },
    "PermissionsPolicy": {
      "Enabled": false
    },
    "ClearSiteData": {
      "Enabled": false
    }
  },
  "Archive": {
    "Enabled": false
  }
}