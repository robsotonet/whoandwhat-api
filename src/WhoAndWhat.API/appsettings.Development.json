{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Information",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=whoandwhat;Username=postgres;Password=postgres",
    "ApplicationInsights": ""
  },
  "DetailedErrors": true,
  "ASPNETCORE_FORCE_HTTPS": "false",
  "OAuth": {
    "Google": {
      "ClientId": "your-google-client-id-for-development",
      "ClientSecret": "your-google-client-secret-for-development"
    },
    "Facebook": {
      "AppId": "your-facebook-app-id-for-development",
      "AppSecret": "your-facebook-app-secret-for-development"
    },
    "Apple": {
      "ClientId": "your-apple-client-id-for-development",
      "TeamId": "your-apple-team-id-for-development",
      "KeyId": "your-apple-key-id-for-development",
      "PrivateKey": "your-apple-private-key-for-development"
    },
    "CallbackUrl": {
      "BaseUrl": "http://localhost:5000"
    }
  },
  "JWT": {
    "SecretKey": "DevelopmentSuperSecretKeyThatShouldBeAtLeast32CharactersLong!",
    "Issuer": "WhoAndWhatAPI-Dev",
    "Audience": "WhoAndWhatClients-Dev"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 500
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 5000
      }
    ]
  },
  "ClientRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 1000
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 10000
      }
    ]
  },
  "KeyVault": {
    "Endpoint": ""
  },
  "DDoSProtection": {
    "Enabled": true,
    "DetailedLogging": true,
    "WhitelistedIPs": [
      "127.0.0.1",
      "::1",
      "localhost"
    ],
    "BlockDurationMinutes": 5,
    "MaxRequestsPerWindow": 500,
    "RequestFrequencyWindowMinutes": 5,
    "ScoreAccumulationWindowMinutes": 15,
    "PatternAnalysisWindowMinutes": 10,
    "BlockingThreshold": 200,
    "ImmediateBlockThreshold": 100,
    "LogSuspiciousThreshold": 50,
    "BotUserAgentPenalty": 10,
    "SuspiciousPathPenalty": 15,
    "HighFrequencyPenalty": 15,
    "ExcessiveEndpointsPenalty": 10,
    "UserAgentVariationPenalty": 5,
    "MaxUniqueEndpointsThreshold": 50,
    "MaxUserAgentChangesThreshold": 10
  },
  "SecurityHeaders": {
    "Enabled": true,
    "RemoveServerHeader": true,
    "XContentTypeOptions": "nosniff",
    "XFrameOptions": "SAMEORIGIN",
    "XXSSProtection": "1; mode=block",
    "ReferrerPolicy": "strict-origin-when-cross-origin",
    "CrossOriginEmbedderPolicy": "unsafe-none",
    "CrossOriginOpenerPolicy": "unsafe-none",
    "CrossOriginResourcePolicy": "cross-origin",
    "XPermittedCrossDomainPolicies": "none",
    "HSTS": {
      "Enabled": false,
      "MaxAge": 300,
      "IncludeSubDomains": false,
      "Preload": false
    },
    "ContentSecurityPolicy": {
      "Enabled": true,
      "ReportOnly": true,
      "UseNonce": false,
      "DefaultSrc": "'self'",
      "ScriptSrc": "'self' 'unsafe-inline' 'unsafe-eval'",
      "StyleSrc": "'self' 'unsafe-inline'",
      "ImgSrc": "'self' data: https: http:",
      "FontSrc": "'self' data:",
      "ConnectSrc": "'self' ws: wss: http: https:",
      "MediaSrc": "'self'",
      "ObjectSrc": "'none'",
      "ChildSrc": "'self'",
      "FrameAncestors": "'self'",
      "FormAction": "'self'",
      "BaseUri": "'self'",
      "UpgradeInsecureRequests": false,
      "BlockAllMixedContent": false
    },
    "PermissionsPolicy": {
      "Enabled": true,
      "Camera": "()",
      "Microphone": "()",
      "Geolocation": "()",
      "Gyroscope": "()",
      "Accelerometer": "()",
      "Magnetometer": "()",
      "Payment": "()",
      "Usb": "()",
      "PictureInPicture": "()",
      "Fullscreen": "'self'",
      "Autoplay": "'self'",
      "EncryptedMedia": "()"
    },
    "ClearSiteData": {
      "Enabled": false,
      "ClearCache": false,
      "ClearCookies": true,
      "ClearStorage": false,
      "ClearExecutionContexts": false,
      "TriggerEndpoints": ["/api/v1/auth/logout", "/logout"]
    }
  }
}
