# Example environment variables file
# Copy this to .env and update values for local development

# Application Environment
ASPNETCORE_ENVIRONMENT=Development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=WhoAndWhat
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET_KEY=YourDevelopmentSecretKeyHere_MinimumLength32Characters
JWT_ISSUER=WhoAndWhat-API
JWT_AUDIENCE=WhoAndWhat-Client
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# Redis Configuration
REDIS_CONNECTION_STRING=localhost:6379

# Logging Configuration
LOGGING_LEVEL=Information

# Email Configuration (for future use)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@whoandwhat.com

# External API Keys (for future use)
OPENAI_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
APPLE_CLIENT_ID=
APPLE_KEY_ID=
APPLE_TEAM_ID=

# File Storage (for future use)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=whoandwhat-files

# Application Insights (for production)
APPLICATIONINSIGHTS_CONNECTION_STRING=